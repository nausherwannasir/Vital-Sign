FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY my-vitals-ui/package*.json ./

# Install dependencies
RUN npm ci

# Copy application code
COPY my-vitals-ui/ .

# Build the app
RUN npm run build

# Use a lightweight server for production
FROM node:18-alpine
WORKDIR /app
RUN npm install -g serve
COPY --from=0 /app/dist ./dist

EXPOSE 3001

CMD ["serve", "-s", "dist", "-l", "3001"]
