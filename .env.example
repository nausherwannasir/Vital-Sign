# Flask
FLASK_ENV=development
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=3000

# Signal processing
SAMPLING_RATE=30          # fallback fps if the client doesn't report a measured rate
MIN_SIGNAL_LENGTH=50
MIN_HR_FREQ=0.8           # 48 BPM
MAX_HR_FREQ=3.0           # 180 BPM
FFT_LENGTH=4096           # zero-padded FFT size; controls BPM resolution

# CORS / logging
CORS_ORIGINS=*
LOG_LEVEL=INFO
